{
    "name": "@palasthotel/additional-authors",
    "version": "1.3.9",
    "scripts": {
		"build": "npm run build:scripts && npm run build:blocks",
        "build:scripts": "wp-scripts build ./src/gutenberg.js ./src/meta-box.js ./src/users-table.ts",
		"build:blocks": "wp-scripts build --webpack-src-dir=./src-blocks --output-path=./build/blocks",
		"start:blocks": "wp-scripts start --webpack-src-dir=./src-blocks --output-path=./build/blocks",
        "pack": "./bin/build-plugin.sh"
    },
    "dependencies": {
        "@wordpress/components": "^25.14.0",
        "@wordpress/data": "^9.18.0",
        "@wordpress/edit-post": "^7.25.0",
        "@wordpress/element": "^5.25.0",
        "@wordpress/plugins": "^6.16.0",
        "prop-types": "^15.8.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "underscore": "^1.13.6"
    },
    "devDependencies": {
        "@wordpress/prettier-config": "^4.44.0",
        "@wordpress/scripts": "^32.0.0",
        "@types/wordpress__block-editor": "^15.0.0",
        "@types/wordpress__blocks": "^12.5.18",
        "@wordpress/block-editor": "^14.20.0",
        "@wordpress/blocks": "^15.10.0",
        "@wordpress/components": "^31.0.0",
        "@wordpress/core-data": "^7.37.0",
        "@wordpress/data": "^10.37.0",
        "@wordpress/edit-post": "^8.37.0",
        "@wordpress/element": "^6.37.0",
        "@wordpress/i18n": "^6.10.0",
        "@wordpress/icons": "^11.4.0",
        "@wordpress/server-side-render": "^6.13.0"
    }
